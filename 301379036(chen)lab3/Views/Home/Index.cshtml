@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Podcast Management</h1>
    <p class="lead">Manage podcasts, episodes, subscriptions, and listener interactions</p>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <p>
            Welcome, <strong>@User.Identity.Name</strong>
        </p>

	    <a class="btn btn-primary" asp-controller="Episode" asp-action="Index">Browse Episodes</a>
        <a class="btn btn-secondary" asp-controller="Podcast" asp-action="Index">Browse Podcasts</a>

        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" style="display:inline;">
            <button type="submit" class="btn btn-danger">
                Logout
            </button> 
        </form>
    }
    else
    {
        <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
        <a class="btn btn-secondary" asp-area="Identity" asp-page="/Account/Register">Register</a>
    }

</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        Episodes
                    </h5>
                    <p class="card-text">
                        Browse, search, and listen to podcast episodes.
                    </p>
                    <a class="btn btn-primary"
                       asp-controller="Episode"
                       asp-action="Index">
                        View Episodes
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        Podcasts
                    </h5>
                    <p class="card-text">
                        Create and manage podcasts.
                    </p>
                    <a class="btn btn-primary"
                       asp-controller="Podcast"
                       asp-action="Index">
                        View Podcasts
                    </a>
                </div>
            </div>
        </div>


        <div class="col-md-4">
            <div class="card">
                <div class="card-body">

                    <h5 class="card-title">
                        Subscriptions
                    </h5>

                    <p class="card-text">
                        Manage podcast subscriptions.
                    </p>

                    <a class="btn btn-primary"
                       asp-controller="Subscription"
                       asp-action="Index">
                        View Subscriptions
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>
